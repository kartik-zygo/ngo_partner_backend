# ─── Server ───────────────────────────────────────────────────────────────────
NODE_ENV=development
PORT=4000
API_PREFIX=/api/v1

# ─── Database ─────────────────────────────────────────────────────────────────
# Requires PostgreSQL 14+ installed locally.
# Create the DB manually before running migrations:
#   psql -U postgres -c "CREATE USER ngo_admin WITH PASSWORD 'changeme_local';"
#   psql -U postgres -c "CREATE DATABASE ngo_partners_db OWNER ngo_admin;"
DB_HOST=localhost
DB_PORT=5432
DB_USER=ngo_admin
DB_PASSWORD=changeme_local
DB_NAME=ngo_partners_db
DB_POOL_MIN=2
DB_POOL_MAX=10
DB_SSL=false

# ─── JWT ──────────────────────────────────────────────────────────────────────
# Generate with: node -e "console.log(require('crypto').randomBytes(64).toString('hex'))"
JWT_ACCESS_SECRET=REPLACE_WITH_64_BYTE_HEX_SECRET
JWT_REFRESH_SECRET=REPLACE_WITH_ANOTHER_64_BYTE_HEX_SECRET
JWT_ACCESS_EXPIRES_IN=15m
JWT_REFRESH_EXPIRES_IN=7d

# ─── Security ─────────────────────────────────────────────────────────────────
# Comma-separated list of allowed CORS origins
CORS_ORIGINS=http://localhost:3000,http://localhost:8080
REQUEST_SIZE_LIMIT=10mb

# Rate limiting (requests per window)
RATE_LIMIT_WINDOW_MS=900000
RATE_LIMIT_MAX=200
AUTH_RATE_LIMIT_MAX=20

# Account lockout: max failed attempts before lock
AUTH_MAX_FAILED_ATTEMPTS=5
AUTH_LOCK_DURATION_MINUTES=15

# ─── Logging ──────────────────────────────────────────────────────────────────
LOG_LEVEL=debug

# ─── Optional: OTP (disabled by default) ─────────────────────────────────────
OTP_ENABLED=false
# OTP_EXPIRY_MINUTES=5

# ─── App URL (for docs, etc.) ─────────────────────────────────────────────────
APP_URL=http://localhost:4000

# ─── Ngrok tunnel (dev only) ──────────────────────────────────────────────────
# Get your free authtoken at: https://dashboard.ngrok.com/get-started/your-authtoken
# Then run: npm run dev:tunnel
# The public HTTPS URL is printed on startup — use it as baseUrl in Flutter apps.
# NGROK_AUTHTOKEN=

# ─── Cashfree Payment Gateway ─────────────────────────────────────────────────
# 1. Sign up at https://merchant.cashfree.com  (sandbox: https://merchant.cashfree.com/pg/login)
# 2. Go to "Payment Gateway" → "Credentials" in the sandbox dashboard
# 3. Copy "App ID" and "Secret Key" below

CASHFREE_APP_ID=your_sandbox_app_id
CASHFREE_SECRET_KEY=your_sandbox_secret_key

# sandbox (default for local dev) | production
CASHFREE_ENVIRONMENT=sandbox

# Webhook notify URL — Cashfree will POST payment events here.
# For local dev, start the ngrok tunnel (npm run dev:tunnel) and set the public URL:
#   CASHFREE_WEBHOOK_NOTIFY_URL=https://<your-ngrok-id>.ngrok-free.app/api/v1/orders/webhook
# On a live server this defaults to APP_URL/api/v1/orders/webhook, so leave it blank.
# CASHFREE_WEBHOOK_NOTIFY_URL=
