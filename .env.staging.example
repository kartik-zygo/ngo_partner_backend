# ─── Staging Server Environment ───────────────────────────────────────────────
# Copy this to .env on the Digital Ocean droplet and fill in real values.
# NEVER commit the actual .env file to git.

# ─── Server ───────────────────────────────────────────────────────────────────
NODE_ENV=staging
PORT=4000
API_PREFIX=/api/v1

# ─── Database ─────────────────────────────────────────────────────────────────
DB_HOST=localhost
DB_PORT=5432
DB_USER=ngo_admin
DB_PASSWORD=CHANGE_THIS_TO_A_STRONG_PASSWORD
DB_NAME=ngo_partners_staging
DB_POOL_MIN=2
DB_POOL_MAX=10
# Set to true if using DigitalOcean Managed PostgreSQL (requires SSL)
DB_SSL=false

# ─── JWT ──────────────────────────────────────────────────────────────────────
# Generate each secret with: node -e "console.log(require('crypto').randomBytes(64).toString('hex'))"
JWT_ACCESS_SECRET=REPLACE_WITH_64_BYTE_HEX_SECRET
JWT_REFRESH_SECRET=REPLACE_WITH_ANOTHER_64_BYTE_HEX_SECRET
JWT_ACCESS_EXPIRES_IN=15m
JWT_REFRESH_EXPIRES_IN=7d

# ─── Security ─────────────────────────────────────────────────────────────────
# Your Flutter app origins and any staging frontend URLs
CORS_ORIGINS=https://your-staging-domain.com
REQUEST_SIZE_LIMIT=10mb
RATE_LIMIT_WINDOW_MS=900000
RATE_LIMIT_MAX=200
AUTH_RATE_LIMIT_MAX=20
AUTH_MAX_FAILED_ATTEMPTS=5
AUTH_LOCK_DURATION_MINUTES=15

# ─── Logging ──────────────────────────────────────────────────────────────────
LOG_LEVEL=info

# ─── App URL ──────────────────────────────────────────────────────────────────
APP_URL=https://api.your-staging-domain.com

# ─── Agora RTC (optional) ─────────────────────────────────────────────────────
# Leave blank if not using voice/video call features
# AGORA_APP_ID=
# AGORA_APP_CERTIFICATE=
AGORA_TOKEN_EXPIRY_SECONDS=3600

# ─── IMPORTANT: Seed data ─────────────────────────────────────────────────────
# DO NOT set ENABLE_SEED=true on the staging server.
# Seeds only run when explicitly set: ENABLE_SEED=true npm run seed:run
